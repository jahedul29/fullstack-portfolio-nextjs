# Node environment (development | production | test)
NODE_ENV=development

# --- Database ---
# MongoDB connection string (Atlas SRV URI, local mongod, or Docker) used by Mongoose
DATABASE_URL=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/fullstack-portfolio?retryWrites=true&w=majority

# --- Auth ---
# Cost factor for bcryptjs password hashing
BCRYPT_SALT_ROUNDS=12
# Secret used to sign access tokens
JWT_SECRET=
# Secret used to sign refresh tokens
JWT_REFRESH_SECRET=
# Access token lifetime (e.g. 1d, 12h)
JWT_EXPIRES_IN=1d
# Refresh token lifetime (e.g. 30d)
JWT_REFRESH_EXPIRES_IN=30d

# --- App URL ---
# Public origin of the app; the landing pages fetch their own /api/v1/* using this,
# and the demo seed script (npm run seed) uses it to find the running server.
# Set to http://localhost:3000 locally, and to the deployed URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Site / SEO (all optional) ---
# Brand name used as a fallback wherever the owner record isn't loaded yet (nav, footer, SEO)
NEXT_PUBLIC_SITE_NAME=Portfolio
# Twitter/X handle (with @) used for the twitter:site/twitter:creator meta tags
NEXT_PUBLIC_TWITTER_HANDLE=
# Optional search-console verification codes (server-only; only rendered when set)
SITE_VERIFICATION_GOOGLE=
SITE_VERIFICATION_YANDEX=
SITE_VERIFICATION_YAHOO=

# --- Cloudinary (signed image uploads from the admin panel; optional — manual image
# URLs work fine without it) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
# Server-only secret used to sign upload requests — never exposed to the browser
CLOUDINARY_API_SECRET=

# --- Contact form (optional) ---
# Webhook POSTed to (fire-and-forget) whenever a contact-form message is created;
# the message is saved to the admin Messages inbox regardless of whether this fires
MESSAGE_NOTIFY_WEBHOOK_URL=

# --- First admin user (used by `npm run seed:admin`, and to log in for `npm run seed`) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional, defaults to "Admin"
ADMIN_NAME=Admin
# Optional, defaults to "N/A"
ADMIN_PHONE=
# Optional, defaults to "N/A"
ADMIN_ADDRESS=
