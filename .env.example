NODE_ENV=development
DATABASE_URL=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/fullstack-portfolio?retryWrites=true&w=majority
BCRYPT_SALT_ROUNDS=12
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Brand name used as a fallback wherever the owner record isn't loaded yet (nav, footer, SEO)
NEXT_PUBLIC_SITE_NAME=Portfolio
# Twitter/X handle (with @) used for the twitter:site/twitter:creator meta tags
NEXT_PUBLIC_TWITTER_HANDLE=
# Optional search-console verification codes (server-only; only rendered when set)
SITE_VERIFICATION_GOOGLE=
SITE_VERIFICATION_YANDEX=
SITE_VERIFICATION_YAHOO=

# Used only by `npm run seed:admin` to create the first admin user
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
ADMIN_PHONE=
ADMIN_ADDRESS=

# Cloudinary (signed image uploads from the admin panel)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
